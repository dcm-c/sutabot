<div class="mb-3 border-top border-secondary pt-3 mt-2">
  <label class="text-white small fw-bold text-uppercase" style="color: #ff007f !important;">Hova kerüljenek a privát Ticket csatornák?</label>
  <input type="text" name="config[custom_data][category_id]" value="<%= config.custom_data['category_id'] rescue '' %>" class="form-control bg-dark text-white border-secondary mb-3" placeholder="Kategória ID (Pl: 1045...)" required>

  <label class="text-white small fw-bold text-uppercase" style="color: #ff007f !important;">Hova írja ki a szavazást? (Poll)</label>
  <select name="config[custom_data][voting_channel_id]" class="form-select custom-select-dark mb-3">
    <option value="">-- Válassz csatornát --</option>
    <% @channels.each do |c| %>
      <option value="<%= c['id'] %>" <%= 'selected' if (config.custom_data['voting_channel_id'] rescue '') == c['id'] %>># <%= c['name'] %></option>
    <% end %>
  </select>

  <label class="text-white small fw-bold text-uppercase" style="color: #ff007f !important;">Hova másolja az Elfogadott bemutatkozást?</label>
  <select name="config[custom_data][intro_channel_id]" class="form-select custom-select-dark mb-3">
    <option value="">-- Válassz csatornát --</option>
    <% @channels.each do |c| %>
      <option value="<%= c['id'] %>" <%= 'selected' if (config.custom_data['intro_channel_id'] rescue '') == c['id'] %>># <%= c['name'] %></option>
    <% end %>
  </select>

  <label class="text-white small fw-bold text-uppercase" style="color: #ff007f !important;">Hova küldje a Transcriptet (Log)?</label>
  <select name="config[custom_data][transcript_channel_id]" class="form-select custom-select-dark mb-3">
    <option value="">-- Válassz csatornát --</option>
    <% @channels.each do |c| %>
      <option value="<%= c['id'] %>" <%= 'selected' if (config.custom_data['transcript_channel_id'] rescue '') == c['id'] %>># <%= c['name'] %></option>
    <% end %>
  </select>

  <div class="row">
    <div class="col-md-6">
      <label class="text-success small fw-bold mb-1">Elfogadáskor ADJA MEG ezt a rangot:</label>
      <select name="config[custom_data][grant_role_id]" class="form-select custom-select-dark mb-3">
        <option value="">-- Nincs rangadás --</option>
        <% @roles.each do |r| %>
          <option value="<%= r['id'] %>" <%= 'selected' if (config.custom_data['grant_role_id'] rescue '') == r['id'] %>>@ <%= r['name'] %></option>
        <% end %>
      </select>
    </div>
    <div class="col-md-6">
      <label class="text-danger small fw-bold mb-1">Elfogadáskor VEDD EL ezt a rangot:</label>
      <select name="config[custom_data][remove_role_id]" class="form-select custom-select-dark mb-3">
        <option value="">-- Nincs rangelvétel --</option>
        <% @roles.each do |r| %>
          <option value="<%= r['id'] %>" <%= 'selected' if (config.custom_data['remove_role_id'] rescue '') == r['id'] %>>@ <%= r['name'] %></option>
        <% end %>
      </select>
    </div>
  </div>
  <hr class="border-secondary mt-3 mb-3">
  
  <div class="row">
    <div class="col-md-8">
      <label class="text-white small fw-bold text-uppercase" style="color: #ff007f !important;">Kérdés / Felszólítás a felugró ablakban:</label>
      <input type="text" name="config[custom_data][question_label]" value="<%= config.custom_data['question_label'] || 'Írj magadról pár mondatot!' %>" class="form-control bg-dark text-white border-secondary mb-3" placeholder="Pl: Miért szeretnél csatlakozni? (Max 45 kar.)" maxlength="45">
    </div>
    <div class="col-md-4">
      <label class="text-white small fw-bold text-uppercase" style="color: #ff007f !important;">Min. karakter:</label>
      <input type="number" name="config[custom_data][min_length]" value="<%= config.custom_data['min_length'] || 50 %>" class="form-control bg-dark text-white border-secondary mb-3" min="1" max="3000">
    </div>
  </div>
</div>