<%= form_with model: rule, url: rule.new_record? ? server_server_rules_path(@guild_id) : server_server_rule_path(@guild_id, rule), local: true do |f| %>

  <% 
    rule.actions ||= {}
    rule.conditions ||= {}
    @channels ||= []
    @roles ||= []
    text_channels = @channels.select { |c| c['type'] == 0 }
    categories = @channels.select { |c| c['type'] == 4 }
    cat = @category || (['ticket', 'regex', 'automod'].include?(rule.rule_type) ? 'mod' : 'fun')
    
   type_options = if cat == 'mod'
                     [["🎫 Ticket Rendszer", "ticket"], ["📝 Regex Szűrő", "regex"], ["🤖 Automod (Spam/Caps)", "automod"]]
                   else
                     [
                       ["💬 AutoResponder", "autoresponder"], 
                       ["🎭 Reakció Rangok", "reaction_role"], 
                       ["👋 Üdvözlő / Belépő", "welcome"],
                       ["📱 Reddit Feed", "reddit_feed"]
                     ]
                   end
  %>

  <div class="bg-dark p-4 rounded-3 shadow-lg border border-secondary" data-controller="rule-form">

    <div class="row mb-4 border-bottom border-secondary pb-4">
      <div class="col-md-6">
        <%= f.label :name, "Szabály (Folyamat) Neve", class: "form-label text-white fw-bold" %>
        <%= f.text_field :name, class: "form-control bg-black text-white border-secondary", required: true %>
      </div>
      <div class="col-md-6">
        <%= f.label :rule_type, "Modul Típusa", class: "form-label text-white fw-bold" %>
        <%= f.select :rule_type, type_options, {}, class: "form-select bg-black text-white border-secondary", data: { "rule-form-target" => "selector", action: "change->rule-form#switch" } %>
      </div>
    </div>

    <%= render 'server_rules/panels/middleware', rule: rule, text_channels: text_channels, categories: categories, roles: @roles %>

    <h4 class="text-white fw-bold mb-3 mt-4">🛠️ Modul Beállítások</h4>

    <%= render 'server_rules/panels/ticket', rule: rule, text_channels: text_channels, categories: categories, roles: @roles %>
    <%= render 'server_rules/panels/regex', rule: rule %>
    <%= render 'server_rules/panels/automod', rule: rule %>
    <%= render 'server_rules/panels/autoresponder', rule: rule %>
    <%= render 'server_rules/panels/reaction_role', rule: rule, text_channels: text_channels, roles: @roles %>
    <%= render 'server_rules/panels/welcome', rule: rule, text_channels: text_channels, roles: @roles %>
    <%= render 'server_rules/panels/nyaugator', rule: rule %>
    <%= render 'server_rules/panels/horoscope', rule: rule %>
    <%= render 'server_rules/panels/bible', rule: rule, text_channels: text_channels %>
    <%= render 'server_rules/panels/reddit_feed', rule: rule, text_channels: text_channels %>

    <div class="mt-4 border-top border-secondary pt-3 d-flex justify-content-between align-items-center">
      <div class="form-check form-switch">
        <%= f.check_box :active, class: "form-check-input", checked: rule.new_record? ? true : rule.active %>
        <%= f.label :active, "Szabály bekapcsolása", class: "form-check-label text-white fw-bold" %>
      </div>
      <%= f.submit "🚀 Folyamat Mentése", class: "btn fw-bold text-white px-5", style: "background-color: #ff007f;" %>
    </div>

  </div> <%= render 'server_rules/permission_modal' %>

<% end %>