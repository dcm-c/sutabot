    <div class="card-header text-info fw-bold border-secondary">♈ HOROSZKÓP BEÁLLÍTÁSOK</div>
    <div class="card-body">
      <label class="text-secondary small">Alap parancs (pl: !horoszkop):</label>
      <input type="text" name="server_rule[conditions][trigger_word]" value="<%= rule.conditions['trigger_word'] %>" class="form-control bg-dark text-white border-secondary mb-3">
