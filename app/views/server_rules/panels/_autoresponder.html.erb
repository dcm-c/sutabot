<div id="panel-autoresponder" class="workflow-panel" data-rule-form-target="panel" style="display: none;">
  <div class="card bg-black border-secondary mb-3">
    <div class="card-header text-success fw-bold border-secondary">💬 AUTOMATIKUS VÁLASZ BEÁLLÍTÁSA</div>
    <div class="card-body">
      <div class="row">
        <div class="col-md-6 mb-3">
          <label class="text-secondary small">Figyelt szó vagy Parancs (Pl: !ping):</label>
          <input type="text" name="server_rule[conditions][trigger_word]" value="<%= rule.conditions['trigger_word'] %>" class="form-control bg-dark text-white border-secondary">
        </div>
        <div class="col-md-6 mb-3">
          <label class="text-secondary small">A bot válasza:</label>
          <textarea name="server_rule[actions][reply_text]" class="form-control bg-dark text-white border-secondary" rows="2"><%= rule.actions['reply_text'] %></textarea>
        </div>
      </div>
    </div>
  </div>
</div>