<div id="panel-reaction_role" class="workflow-panel" data-rule-form-target="panel" style="display: none;">
  <div class="card bg-black border-secondary mb-3">
    <div class="card-header text-info fw-bold border-secondary">🎭 REAKCIÓ RANGOK</div>
    <div class="card-body">
      <div class="row">
        <div class="col-md-6 mb-3">
          <label class="text-secondary small">Panel Csatorna:</label>
          <select name="server_rule[conditions][trigger_channel_id]" class="form-select bg-dark text-white border-secondary"><option value="">-- Válassz csatornát --</option><% text_channels.each do |c| %><option value="<%= c['id'] %>" <%= 'selected' if rule.conditions['trigger_channel_id'] == c['id'] %>># <%= c['name'] %></option><% end %></select>
        </div>
      </div>
      <div class="row mt-3 border-top border-secondary pt-3">
        <% (1..3).each do |i| %>
          <div class="col-md-4 mb-2">
            <label class="text-secondary small">Emoji <%= i %>:</label>
            <input type="text" name="server_rule[actions][reactions][<%= i %>][emoji]" value="<%= rule.actions.dig('reactions', i.to_s, 'emoji') %>" class="form-control bg-black text-white border-secondary">
            <select name="server_rule[actions][reactions][<%= i %>][role_id]" class="form-select bg-black text-white border-secondary mt-1"><option value="">-- Rang --</option><% roles.each do |r| %><option value="<%= r['id'] %>" <%= 'selected' if rule.actions.dig('reactions', i.to_s, 'role_id') == r['id'] %>>@ <%= r['name'] %></option><% end %></select>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>