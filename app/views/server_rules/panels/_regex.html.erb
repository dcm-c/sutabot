<div id="panel-regex" class="workflow-panel" data-rule-form-target="panel" style="display: none;">
  <div class="card bg-black border-secondary mb-3">
    <div class="card-header text-warning fw-bold border-secondary">📍 REGEX BEÁLLÍTÁSOK</div>
    <div class="card-body">
      <label class="text-secondary small">Tiltott szavak (vesszővel elválasztva):</label>
      <textarea name="server_rule[conditions][banned_words]" class="form-control bg-dark text-white border-secondary mb-2" rows="2"><%= rule.conditions['banned_words'] %></textarea>
      <div class="form-check form-switch mb-3"><input type="hidden" name="server_rule[actions][delete_message]" value="false"><input class="form-check-input" type="checkbox" name="server_rule[actions][delete_message]" value="true" id="del_msg" <%= 'checked' if rule.actions['delete_message'] == 'true' %>><label class="form-check-label text-white small" for="del_msg">Azonnal Törölje az üzenetet</label></div>
      <div class="row">
        <div class="col-md-8">
          <label class="text-secondary small">Figyelmeztető üzenet:</label>
          <input type="text" name="server_rule[actions][warn_message]" value="<%= rule.actions['warn_message'] %>" class="form-control bg-dark text-white border-secondary mb-3">
        </div>
        <div class="col-md-4">
          <label class="text-secondary small">Timeout adása (perc):</label>
          <input type="number" name="server_rule[actions][timeout_minutes]" value="<%= rule.actions['timeout_minutes'] || 0 %>" class="form-control bg-dark text-white border-secondary">
        </div>
      </div>
    </div>
  </div>
</div>