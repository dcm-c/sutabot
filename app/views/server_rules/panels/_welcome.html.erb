<div id="panel-welcome" class="workflow-panel" data-rule-form-target="panel" style="display: none;">
  <div class="card bg-black border-secondary mb-3">
    <div class="card-header text-success fw-bold border-secondary">👋 ÜDVÖZLŐ RENDSZER</div>
    <div class="card-body">
      <div class="row">
        <div class="col-md-4 mb-2">
          <label class="text-secondary small fw-bold">📥 Belépés Csatorna:</label>
          <select name="server_rule[actions][welcome_channel_id]" class="form-select bg-dark text-white border-secondary"><option value="">-- Ne küldjön --</option><% text_channels.each do |c| %><option value="<%= c['id'] %>" <%= 'selected' if rule.actions['welcome_channel_id'] == c['id'] %>># <%= c['name'] %></option><% end %></select>
        </div>
        <div class="col-md-8 mb-2">
          <label class="text-secondary small fw-bold">Belépő üzenet:</label>
          <input type="text" name="server_rule[actions][welcome_message]" value="<%= rule.actions['welcome_message'] %>" class="form-control bg-dark text-white border-secondary">
        </div>
      </div>
    </div>
  </div>
</div>