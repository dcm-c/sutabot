<% 
  badge_color = case rule.rule_type
                when 'ticket' then 'bg-primary'
                when 'regex' then 'bg-warning text-dark'
                when 'automod' then 'bg-danger'
                when 'autoresponder' then 'bg-success'
                when 'reaction_role' then 'bg-info text-dark'
                else 'bg-secondary'
                end
  
  opacity = rule.active ? "1.0" : "0.5"
%>

<div class="col-md-6 col-lg-4 mb-4">
  <div class="card h-100 border-secondary shadow" style="background-color: #242424; opacity: <%= opacity %>; transition: 0.3s;">
    <div class="card-body d-flex flex-column">
      <div class="d-flex justify-content-between align-items-start mb-3">
        <span class="badge <%= badge_color %> rounded-pill text-uppercase px-3 py-2 shadow-sm"><%= rule.rule_type %></span>
        
        <%= button_to toggle_server_server_rule_path(@guild_id, rule), method: :patch, class: "btn btn-sm #{rule.active ? 'btn-success' : 'btn-outline-secondary'}", style: "border-radius: 20px;" do %>
          <%= rule.active ? "🟢 Aktív" : "⚫ Inaktív" %>
        <% end %>
      </div>
      
      <h4 class="card-title text-white fw-bold text-truncate" title="<%= rule.name %>"><%= rule.name %></h4>
      
      <div class="d-flex gap-2 mt-auto border-top border-secondary pt-3">
        <%= link_to "✏️ Szerkesztés", edit_server_server_rule_path(@guild_id, rule), class: "btn btn-outline-light btn-sm flex-grow-1" %>
        
        <% if rule.rule_type == 'ticket' %>
          <%= button_to "📤 Kihelyezés", deploy_server_server_rule_path(@guild_id, rule), method: :post, class: "btn btn-primary btn-sm" %>
        <% end %>

        <%= button_to "🗑️", server_server_rule_path(@guild_id, rule), method: :delete, data: { turbo_confirm: "Biztosan végleg törölni szeretnéd?" }, class: "btn btn-outline-danger btn-sm" %>
      </div>
    </div>
  </div>
</div>