<div class="container mt-4 mb-5">
  <div class="d-flex justify-content-between align-items-end mb-4 border-bottom border-secondary pb-2">
    <div>
      <h2 class="text-white fw-bold m-0">⚙️ Szerver Modulok és Szabályok</h2>
      <p class="text-secondary small mt-1 mb-0">Itt hozhatsz létre korlátlan számú egyedi folyamatot.</p>
    </div>
  </div>

  <ul class="nav nav-tabs border-secondary mb-4" id="moduleTabs" role="tablist">
    <li class="nav-item" role="presentation">
      <button class="nav-link active bg-transparent text-white border-secondary border-bottom-0 fw-bold" id="mod-tab" data-bs-toggle="tab" data-bs-target="#mod-pane" type="button" role="tab">
        🛡️ Moderáció & Support
      </button>
    </li>
    <li class="nav-item" role="presentation">
      <button class="nav-link bg-transparent text-secondary border-secondary border-bottom-0 fw-bold" id="fun-tab" data-bs-toggle="tab" data-bs-target="#fun-pane" type="button" role="tab">
        🎉 Fun & Szórakozás
      </button>
    </li>
  </ul>

  <div class="tab-content" id="moduleTabsContent">
    
    <div class="tab-pane fade show active" id="mod-pane" role="tabpanel" tabindex="0">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="text-white">Aktív Moderációs Szabályok</h5>
        <%= link_to "+ Új Moderációs Folyamat", new_server_server_rule_path(@guild_id, category: 'mod'), class: "btn fw-bold px-3 shadow-sm", style: "background-color: #ff007f; color: white; border-radius: 20px; font-size: 0.9rem;" %>
      </div>

      <% if @mod_rules.empty? %>
        <div class="alert bg-dark border-secondary text-center py-4 text-secondary rounded-3">Nincsenek még moderációs / ticket szabályaid.</div>
      <% else %>
        <div class="row">
          <%= render partial: 'rule_card', collection: @mod_rules, as: :rule %>
        </div>
      <% end %>
    </div>

    <div class="tab-pane fade" id="fun-pane" role="tabpanel" tabindex="0">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="text-white">Aktív Fun Szabályok</h5>
        <%= link_to "+ Új Fun Folyamat", new_server_server_rule_path(@guild_id, category: 'fun'), class: "btn fw-bold px-3 shadow-sm", style: "background-color: #5865F2; color: white; border-radius: 20px; font-size: 0.9rem;" %>
      </div>

      <% if @fun_rules.empty? %>
        <div class="alert bg-dark border-secondary text-center py-4 text-secondary rounded-3">Nincsenek még fun / autoresponder szabályaid.</div>
      <% else %>
        <div class="row">
          <%= render partial: 'rule_card', collection: @fun_rules, as: :rule %>
        </div>
      <% end %>
    </div>

  </div>
</div>

<script>
  // Kijelölés vizuális javítása a fülekre kattintva
  document.querySelectorAll('button[data-bs-toggle="tab"]').forEach(tab => {
    tab.addEventListener('shown.bs.tab', event => {
      document.querySelectorAll('button[data-bs-toggle="tab"]').forEach(t => t.classList.replace('text-white', 'text-secondary'));
      event.target.classList.replace('text-secondary', 'text-white');
    });
  });
</script>