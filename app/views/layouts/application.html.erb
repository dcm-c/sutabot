<!DOCTYPE html>
<html lang="hu">
  <head>
    <title>Discord Bot Dashboard</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <style>
      body { background-color: #121212; color: #f8f9fa; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
      .navbar { background-color: #d81b60; box-shadow: 0 4px 12px rgba(216, 27, 96, 0.3); }
      .navbar-brand, .nav-link { color: #ffffff !important; font-weight: bold; }
      .card { background-color: #1e1e1e; border: 1px solid #333; border-radius: 12px; }
      .card-title { color: #ff4081; }
      .btn-primary { background-color: #ff4081; border-color: #ff4081; font-weight: bold; }
      .btn-primary:hover { background-color: #f50057; border-color: #f50057; }
      .btn-outline-primary { color: #ff4081; border-color: #ff4081; }
      .btn-outline-primary:hover { background-color: #ff4081; color: #fff; }
      .server-icon { border-radius: 50%; width: 64px; height: 64px; object-fit: cover; border: 2px solid #ff4081; }
      .alert-custom { background-color: rgba(216, 27, 96, 0.2); border-left: 4px solid #d81b60; color: #fff; }
    </style>
  </head>

  <body>
<nav class="navbar navbar-expand-lg navbar-dark" style="background-color: #202225; border-bottom: 1px solid #292b2f;">      <div class="container">
        <a class="navbar-brand" href="/">🤖 Bot Vezérlőpult</a>
        <% if @guild_id.present? %>
          <ul class="navbar-nav me-auto mb-2 mb-lg-0">
            <li class="nav-item">
              <a class="nav-link text-white fw-bold" href="<%= server_settings_path(@guild_id) %>">🎉 Fun Modulok</a>
            </li>
            <li class="nav-item">
              <a class="nav-link fw-bold" style="color: #ff3333;" href="<%= server_moderation_path(@guild_id) %>">🛡️ Moderáció & Biztonság</a>
            </li>
            <li class="nav-item mb-2">
              <%= link_to server_server_rules_path(@guild_id), class: "nav-link text-white d-flex align-items-center" do %>
                <span class="me-2 fs-5">🧩</span> 
                <span class="fw-bold">Szerver Modulok</span>
              <% end %>
            </li>
          </ul>
        <% end %>
        <a class="nav-link ms-4" href="<%= leaderboard_path %>">🏆 Értékelések (Ranglista)</a>
        <div class="d-flex">
          <% if session[:user_id] %>
            <%= button_to "Kijelentkezés", '/logout', method: :get, class: "btn btn-outline-light btn-sm" %>
          <% end %>
        </div>
      </div>
    </nav>

    <main class="container">
      <% if flash[:notice] %>
        <div class="alert alert-custom mb-4"><%= flash[:notice] %></div>
      <% end %>
      
      <%= yield %>
    </main>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
